@model dominio.Disco

@{
    ViewData["Title"] = "Edit";
}

<h1>Editar Disco</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-2">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" class="form-control" name="Id" />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Titulo" class="control-label"></label>
                <input asp-for="Titulo" class="form-control" name ="Titulo"/>
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="FechaLanzamiento" class="control-label"></label>
                <input asp-for="FechaLanzamiento" class="form-control" name="FechaLanzamiento"/>
                <span asp-validation-for="FechaLanzamiento" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="CantidadCanciones" class="control-label"></label>
                <input asp-for="CantidadCanciones" class="form-control" name="CantidadCanciones"/>
                <span asp-validation-for="CantidadCanciones" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Estilo" class="control-label"></label>
                <select asp-for="Estilo.Id" asp-items="(SelectList)ViewBag.Estilos" class="form-control" name="Estilo.Id"></select>
                <span asp-validation-for="CantidadCanciones" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="TipoEdicion" class="control-label"></label>
                <select asp-for="TipoEdicion.Id" asp-items="(SelectList)ViewBag.Ediciones" class="form-control" name="TipoEdicion.Id"> </select>
                <span asp-validation-for="CantidadCanciones" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="UrlTapa" class="control-label"></label>
                <input asp-for="UrlTapa" class="form-control" name="UrlTapa" />
                <span asp-validation-for="UrlTapa" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <input type="submit" value="Guardar" class="btn btn-primary" />
            </div>
        </form>
    </div>
    <div class="col-8 text-center">
        <img src="@Model.UrlTapa" width="350" />
    </div>
</div>

<div>
    <a asp-action="Index">Regresar al listado</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
